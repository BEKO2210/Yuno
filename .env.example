# Kopiere diese Datei zu ".env.local" und trage deine echten Werte ein.
# .env.local wird NICHT in Git gespeichert (siehe .gitignore).
# Diese Datei (.env.example) enthält NUR Platzhalter, keine echten Keys.

# --- Supabase (Auth, Datenbank, Datei-Speicher) ---
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=DEIN_SUPABASE_SERVICE_ROLE_KEY   # nur serverseitig, geheim halten!

# --- Higgsfield (Logo / Visuals) ---
HIGGSFIELD_API_KEY=DEIN_HIGGSFIELD_KEY

# --- Google API (optionaler Fallback) ---
# WICHTIG: Den alten, in der Notiz geleakten Key WIDERRUFEN und neu erstellen.
GOOGLE_API_KEY=DEIN_NEUER_GOOGLE_KEY
